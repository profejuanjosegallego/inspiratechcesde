# Copia este archivo como .env.local y completa los valores.

# Base de datos MongoDB Atlas
MONGODB_URI=mongodb+srv://usuario:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=inspiratech

# Correo SMTP (para verificación de cuenta y avisos)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=tu-correo@gmail.com
SMTP_PASS=clave-de-aplicacion-de-16-digitos
SMTP_FROM="InspiraTech <tu-correo@gmail.com>"

# Secreto para firmar las sesiones (genera uno con: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))")
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio

# Cuenta del profesor (se crea sola la primera vez)
TEACHER_EMAIL=profe@ejemplo.com
TEACHER_NAME=Nombre del Profe
TEACHER_PASSWORD=una-clave-segura

NEXT_PUBLIC_APP_URL=http://localhost:3000
